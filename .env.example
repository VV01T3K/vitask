# Required — Groq API key for AI features
GROQ_API_KEY=

# Optional — public URLs (set when deploying behind a custom domain)
# Defaults to http://localhost:3000 / http://localhost:5107
PUBLIC_FRONTEND_URL=
PUBLIC_BACKEND_URL=

# Optional — host port mappings (override if 3000/5107 are taken)
FRONTEND_HOST_PORT=3000
BACKEND_HOST_PORT=5107

# Optional — enable the Scalar API explorer UI
# When true: backend exposes /scalar; frontend header shows the "API" link
SCALAR_ENABLED=true
