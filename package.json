{
  "name": "vitask",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -r --no-sort dev",
    "check": "vpr -r check",
    "fix": "vpr -r fix",
    "gen": "vpr -r gen",
    "setup": ". ./.env.example && sed \"s|^GROQ_API_KEY=$|GROQ_API_KEY=$(echo $OBFUSCATED | base64 -d | base64 -d)|\" .env.example > .env"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
