  "components": {
    "schemas": {
      "CreateTaskRequest": {
        "required": [
          "title"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 120,
            "minLength": 3,
            "type": "string"
          }
        }
      },
      "CreateTimerRequest": {
        "required": [
          "title",
          "description",
          "aiInstructions"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 120,
            "minLength": 2,
            "type": "string"
          },
          "description": {
            "maxLength": 240,
            "minLength": 1,
            "type": "string"
          },
          "durationSeconds": {
            "maximum": 86400,
            "minimum": 15,
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "aiInstructions": {
            "maxLength": 1000,
            "minLength": 1,
            "type": "string"
          },
          "icon": {
            "type": [
              "null",
              "string"
            ]
          },
          "color": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "HttpValidationProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": [
              "null",
              "string"
            ]
          },
          "title": {
            "type": [
              "null",
              "string"
            ]
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "null",
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "detail": {
            "type": [
              "null",
              "string"
            ]
          },
          "instance": {
            "type": [
              "null",
              "string"
            ]
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      },
      "SetTaskCompletionRequest": {
        "type": "object",
        "properties": {
          "isCompleted": {
            "type": "boolean"
          }
        }
      },
      "TaskResponse": {
        "required": [
          "id",
          "title",
          "isCompleted",
          "completedAt",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "isCompleted": {
            "type": "boolean"
          },
          "completedAt": {
            "type": [
              "null",
              "string"
            ],
            "format": "date-time"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "TimerResponse": {
        "required": [
          "id",
          "title",
          "description",
          "durationSeconds",
          "aiInstructions",
          "icon",
          "color",
          "isDefault",
          "createdAt"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "durationSeconds": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "aiInstructions": {
            "type": "string"
          },
          "icon": {
            "type": "string"
          },
          "color": {
            "type": "string"
          },
          "isDefault": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "UpdateTimerRequest": {
        "required": [
          "title",
          "description",
          "aiInstructions"
        ],
        "type": "object",
        "properties": {
          "title": {
            "maxLength": 120,
            "minLength": 2,
            "type": "string"
          },
          "description": {
            "maxLength": 240,
            "minLength": 1,
            "type": "string"
          },
          "durationSeconds": {
            "maximum": 86400,
            "minimum": 15,
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "aiInstructions": {
            "maxLength": 1000,
            "minLength": 1,
            "type": "string"
          },
          "icon": {
            "type": [
              "null",
              "string"
            ]
          },
          "color": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
