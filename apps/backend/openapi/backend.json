    "/tasks/wrap-up": {
      "post": {
        "tags": [
          "Tasks"
        ],
        "summary": "Mark current completed tasks as wrapped up and return the session batch",
        "operationId": "WrapUpTasks",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TaskResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
